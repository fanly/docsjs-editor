{
  "name": "@coding01/docsjs-editor",
  "version": "0.1.5",
  "description": "Multi-editor integration bridge for docsjs HTML snapshots and DOCX workflows",
  "keywords": [
    "ckeditor",
    "docsjs",
    "editor",
    "quill",
    "tinymce",
    "tiptap",
    "toast-ui",
    "wangEditor"
  ],
  "homepage": "https://docsjs.coding01.cn/",
  "license": "MIT",
  "author": "fanly <fanly@outlook.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fanly/docsjs-editor.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "check": "vp check",
    "lint": "vp lint .",
    "fmt": "vp fmt .",
    "test": "vp test run",
    "test:watch": "vp test",
    "verify": "vp check && vp lint . && vp test run && vp build"
  },
  "dependencies": {
    "@coding01/docsjs": "^1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vite-plus": "^0.1.11"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.11.1"
}
